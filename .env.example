# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: used by admin for privileged writes / storage uploads
SUPABASE_SERVICE_ROLE_KEY=

# Admin auth
ADMIN_PASSWORD=admin123

# Public site URL (canonical, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL=https://example.com

# Store contact is managed in Admin → Cấu hình (site_settings table).

